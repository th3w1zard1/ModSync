[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://addons/kotor_holocron/ui/kotor_holocron_dock.gd" id="1"]

[node name="KotorHolocronDock" type="VBoxContainer"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1")

[node name="Header" type="Label" parent="."]
layout_mode = 2
text = "KOTOR Holocron"

[node name="PathRow" type="HBoxContainer" parent="."]
layout_mode = 2

[node name="PathEdit" type="LineEdit" parent="PathRow"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
placeholder_text = "/path/to/resource.utc"

[node name="BrowseButton" type="Button" parent="PathRow"]
layout_mode = 2
text = "Browse"

[node name="OpenButton" type="Button" parent="PathRow"]
layout_mode = 2
text = "Open"

[node name="StatusLabel" type="Label" parent="."]
unique_name_in_owner = true
layout_mode = 2
text = "PyKotor bridge required"

[node name="InstallList" type="ItemList" parent="."]
unique_name_in_owner = true
layout_mode = 2
custom_minimum_size = Vector2(0, 80)

[node name="EditorHost" type="VBoxContainer" parent="."]
unique_name_in_owner = true
layout_mode = 2
size_flags_vertical = 3

[connection signal="pressed" from="PathRow/BrowseButton" to="." method="_on_browse_pressed"]
[connection signal="pressed" from="PathRow/OpenButton" to="." method="_on_open_pressed"]
